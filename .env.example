# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=commhealth

# Reddit API
# Reddit's public API requires a descriptive User-Agent on every request.
# Replace <your_reddit_username> with your actual Reddit account username.
# If you don't have one, create a free account at https://www.reddit.com/register
REDDIT_USER_AGENT="python:commhealth-analytics:v0.1.0 (by /u/<your_reddit_username>)"
# Seconds between paginated Reddit API requests (min 1.0 without OAuth)
REDDIT_REQUEST_DELAY=1.0

# LLM Provider
# Supported: openai
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
